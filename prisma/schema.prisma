// Prisma schema for the AI social scheduling app.
// Mirrors lib/db/create-social-scheduling-tables.sql so `prisma migrate` produces
// the same tables the app already expects. user_id columns hold Clerk user IDs
// (plain text — there is no auth.users table now that InsForge is gone).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Prisma 7: connection URLs live in prisma.config.ts (for migrations) and on the
  // driver adapter in lib/prisma.ts (for the app at runtime), not here.
  provider = "postgresql"
}

model channel_types {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type            String          @unique
  name            String
  color           String
  character_limit Int             @default(2200)
  created_at      DateTime?       @default(now()) @db.Timestamptz(6)
  user_channels   user_channels[]
}

model user_channels {
  id                  String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String
  channel_type_id     String            @db.Uuid
  provider_account_id String?
  handle              String?
  profile_image       String?
  profile_url         String?
  access_token        String?
  refresh_token       String?
  token_expires_at    DateTime?         @db.Timestamptz(6)
  is_connected        Boolean?          @default(false)
  is_active           Boolean?          @default(true)
  created_at          DateTime?         @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?         @default(now()) @db.Timestamptz(6)
  channel_types       channel_types     @relation(fields: [channel_type_id], references: [id], onDelete: Restrict)
  scheduled_posts     scheduled_posts[]

  @@unique([user_id, channel_type_id])
}

model idea_groups {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String    @unique
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  ideas      ideas[]
}

model ideas {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String
  group_id    String      @db.Uuid
  title       String
  description String?
  images      Json?       @default(dbgenerated("'[]'::jsonb"))
  sort_order  Int?        @default(0)
  created_at  DateTime?   @default(now()) @db.Timestamptz(6)
  updated_at  DateTime?   @default(now()) @db.Timestamptz(6)
  idea_groups idea_groups @relation(fields: [group_id], references: [id], onDelete: Restrict)
}

model scheduled_posts {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String
  user_channel_id String        @db.Uuid
  content         String
  images          Json?         @default(dbgenerated("'[]'::jsonb"))
  scheduled_at    DateTime      @db.Timestamptz(6)
  status          String        @default("draft")
  published_at    DateTime?     @db.Timestamptz(6)
  published_url   String?
  error_message   String?
  created_at      DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at      DateTime?     @default(now()) @db.Timestamptz(6)
  user_channels   user_channels @relation(fields: [user_channel_id], references: [id], onDelete: Cascade)
}
